# YouTube Shorts Pipeline — credentials template
# Copy to .env.local and fill in your values.
# Values here are loaded automatically when the pipeline runs.
# .env.local is gitignored; never commit real credentials.

# ── Script generation (Claude) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6   # default; override to use a different model

# ── Voiceover (ElevenLabs) ────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (default)
# ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Stock footage (Pexels — optional) ─────────────────────────────────────────
# PEXELS_API_KEY=...

# ── Affiliate tracking (Refersion — optional) ─────────────────────────────────
# REFERSION_API_KEY=...
# REFERSION_BASE_URL=https://track.yoursite.com/ref

# ── YouTube upload ────────────────────────────────────────────────────────────
# One-time setup: download youtube_client_secret.json from Google Cloud Console,
# then run: python youtube_auth.py
YOUTUBE_PRIVACY=private    # private | unlisted | public
# YOUTUBE_CLIENT_SECRET_FILE=secrets/youtube_client_secret.json
# YOUTUBE_TOKEN_FILE=secrets/youtube_token.json

# ── Airtable performance tracking ─────────────────────────────────────────────
# One-time setup: run create-schema to get AIRTABLE_BASE_ID
AIRTABLE_API_KEY=pat...
AIRTABLE_WORKSPACE_ID=wsp...
AIRTABLE_BASE_ID=app...
# AIRTABLE_TABLE=Videos

# ── Opus Clip (optional) ──────────────────────────────────────────────────────
# OPUS_CLIP_API_KEY=...

# ── Supabase — goffer.ai signup instrumentation ──────────────────────────
# Used by ChatInterface.tsx (via VITE_ prefix) and goffer_signups_report.py
# Run goffer_signups_schema.sql once in the Supabase SQL editor to create the table.
VITE_GOFFER_SUPABASE_URL=https://xxxx.supabase.co       # embedded in the React bundle (safe — anon key only writes)
VITE_GOFFER_SUPABASE_ANON_KEY=eyJ...                    # public anon key — allow insert, deny select

# ── Supabase — email_waitlist attribution tracking ────────────────────────────
# Get from: Supabase dashboard → your project → Settings → API
# SUPABASE_URL is the "Project URL" (e.g. https://xxxx.supabase.co)
# SUPABASE_ANON_KEY is the public anon key — embed in landing page HTML (safe, client-side)
# SUPABASE_SERVICE_KEY is the service_role key — server/script use only, never expose publicly
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...         # public — paste into REPLACE_WITH_SUPABASE_ANON_KEY in each landing page HTML
SUPABASE_SERVICE_KEY=eyJ...      # private — used by subscriber_report.py only

# Required table (run once in Supabase SQL editor):
#   CREATE TABLE IF NOT EXISTS email_waitlist (
#     id          uuid PRIMARY KEY DEFAULT gen_random_uuid(),
#     email       text NOT NULL,
#     campaign_id text,
#     utm_source  text,
#     utm_medium  text,
#     utm_campaign text,
#     page        text,
#     created_at  timestamptz NOT NULL DEFAULT now()
#   );
#   -- Allow anonymous inserts (landing pages write without auth):
#   ALTER TABLE email_waitlist ENABLE ROW LEVEL SECURITY;
#   CREATE POLICY "anon insert" ON email_waitlist FOR INSERT TO anon WITH CHECK (true);

# ── Resend — transactional email ──────────────────────────────────────────────
# Phase 1 key was send-only. Upgrade to full-access in the Resend dashboard:
#   resend.com → API Keys → create new key with "Full access" permission
# The full-access key lets subscriber_report.py pull contact lists as an attribution fallback.
RESEND_API_KEY=re_...

# ── GA4 — goffer.ai referrer tracking (SOL-3169) ──────────────────────────────
# Steps to activate (one-time setup):
#   1. In GA4 UI → Admin → Account 392608244 → Account access management
#      Add ga4-provisioner@liorsolomonbot.iam.gserviceaccount.com with "Editor" role.
#   2. Run: GA4_ACCOUNT_ID=392608244 python marketing_ids.py ga4 \
#            --site-name "goffer.ai" --domain goffer.ai
#   3. Paste the returned property_id and measurement_id below.
#   4. In Vercel goffer-frontend → Settings → Env Vars, set:
#      VITE_GA_MEASUREMENT_ID=<measurement_id from step 2> → redeploy.
GA4_ACCOUNT_ID=392608244
GA4_PROPERTY_ID_GOFFER=            # numeric property id returned by marketing_ids.py
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX   # set in Vercel (NOT here — frontend env var)

# ── Admin analytics dashboard (SOL-3144) ──────────────────────────────────────
# VITE_GOFFER_ANALYTICS_KEY is the Supabase service_role key, used by the
# /goffer-analytics board route to read signup data for the admin dashboard.
# Keep this in Vercel env vars only — it is visible to board-authenticated users.
# The RLS "service read" policy on goffer_signups scopes reads to this key.
# VITE_GOFFER_ANALYTICS_KEY=eyJ...   # service_role key — set in Vercel only
